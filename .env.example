# ─── REQUIRED ─────────────────────────────────────────────

# Supabase (server + client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (server only)
ANTHROPIC_API_KEY=sk-ant-...

# App secrets — generate with `openssl rand -hex 16`
MASTER_PASSWORD=change_me_long_random
SEED_TOKEN=change_me_long_random

# Public app URL — set to https://your-app.vercel.app on Vercel
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── OPTIONAL: Google (Gmail + Calendar) ─────────────────
# Without these, the app falls back to Demo Mode for all Google features.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ─── OPTIONAL: Apollo enrichment ─────────────────────────
# Without this, Enrich uses demo data (plausible role/phone/linkedin).
APOLLO_API_KEY=

# ─── OPTIONAL: Resend tracked sends ──────────────────────
# Without this, tracked sends are simulated locally.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
